---

---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>Proyección de Letras</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      /* Custom styles in addition to Tailwind for smooth animations */
      .slide-fade-enter {
        opacity: 0;
        transform: translateY(20px);
      }
      .slide-fade-enter-active {
        opacity: 1;
        transform: translateY(0);
        transition:
          opacity 500ms ease-out,
          transform 500ms ease-out;
      }
      .slide-fade-exit {
        opacity: 1;
        transform: translateY(0);
      }
      .slide-fade-exit-active {
        opacity: 0;
        transform: translateY(-20px);
        transition:
          opacity 500ms ease-in,
          transform 500ms ease-in;
      }

      /* Neon glow effect for text */
      .text-glow {
        text-shadow:
          0 0 20px rgba(255, 255, 255, 0.5),
          0 0 40px rgba(120, 180, 255, 0.3);
      }

      /* Title styling */
      #lyric-title {
        font-size: clamp(2.5rem, 6vw, 60px);
        margin-bottom: 1.5rem;
        font-weight: 300;
        letter-spacing: 0.05em;
        opacity: 0.85;
      }

      /* Lyric text styling with responsive font size */
      #lyric-text {
        font-size: clamp(2rem, 8vw, 80px);
      }
    </style>
  </head>
  <body
    class="bg-black text-white h-screen w-screen overflow-hidden font-sans m-0 flex flex-col relative selection:bg-blue-500/30"
  >
    <!-- Animated Background (Default) -->
    <div
      id="default-bg"
      class="absolute inset-0 z-0 bg-gradient-to-br from-indigo-900 via-slate-900 to-black overflow-hidden transition-opacity duration-1000"
    >
      <div
        class="absolute top-0 left-1/4 w-96 h-96 bg-blue-600/20 rounded-full mix-blend-screen filter blur-3xl animate-blob"
      >
      </div>
      <div
        class="absolute bottom-0 right-1/4 w-96 h-96 bg-purple-600/20 rounded-full mix-blend-screen filter blur-3xl animate-blob animation-delay-2000"
      >
      </div>
    </div>

    <!-- Custom Image Background -->
    <div
      id="custom-bg"
      class="absolute inset-0 z-0 bg-cover bg-center transition-opacity duration-1000 opacity-0"
    >
      <!-- Dark overlay to ensure text is always readable -->
      <div class="absolute inset-0 bg-black/40 backdrop-blur-sm"></div>
    </div>

    <!-- Content Container -->
    <main
      class="relative z-10 flex-1 flex items-center justify-center p-4 md:p-8"
    >
      <div id="lyric-container" class="text-center w-full max-w-[98vw]">
        <p
          id="lyric-title"
          class="font-extrabold leading-tight tracking-tight text-glow text-white/95 transition-all duration-500 hidden"
        >
        </p>
        <p
          id="lyric-text"
          class="font-extrabold leading-loose tracking-tight text-glow whitespace-pre-wrap transition-all duration-500 text-white/90"
          style="max-width: 95vw; word-wrap: break-word; overflow-wrap: break-word;"
        >
          Esperando conexión...
        </p>
      </div>
    </main>

    <script>
      const lyricText = document.getElementById("lyric-text");
      const lyricTitle = document.getElementById("lyric-title");
      const customBg = document.getElementById("custom-bg");
      const defaultBg = document.getElementById("default-bg");
      const channel = new BroadcastChannel("lyrics_channel");

      let verses = [];
      let currentSlide = -1;
      let songTitle = "";
      let showingTitle = false;

      channel.onmessage = (event) => {
        const data = event.data;

        if (data.type === "LYRICS_LOADED") {
          verses = data.verses;
          songTitle = data.songTitle || "";
          // Show title first, then ready for the intro
          if (verses.length > 0 && currentSlide === -1) {
            showTitle();
          }
        } else if (data.type === "CHANGE_SLIDE") {
          currentSlide = data.slideIndex;
          showingTitle = false;
          const currentVerse = verses[currentSlide];
          if (currentVerse) {
            const textToDisplay =
              typeof currentVerse === "string"
                ? currentVerse
                : currentVerse.text;
            updateDisplay(textToDisplay);
          }
        } else if (data.type === "SET_BACKGROUND") {
          if (customBg && defaultBg && data.image) {
            customBg.style.backgroundImage = `url(${data.image})`;
            customBg.classList.remove("opacity-0");
            customBg.classList.add("opacity-100");
            // Optionally fade out default bg
            defaultBg.classList.add("opacity-0");
          }
        }
      };

      function showTitle() {
        if (!lyricTitle || !songTitle) return;

        lyricText.classList.remove("slide-fade-enter-active");
        lyricText.classList.add("slide-fade-exit-active");

        setTimeout(() => {
          // Show title
          lyricTitle.textContent = songTitle;
          lyricTitle.classList.remove("hidden");
          lyricTitle.classList.remove("slide-fade-exit-active");
          lyricTitle.classList.add("slide-fade-enter");

          void lyricTitle.offsetWidth;
          lyricTitle.classList.remove("slide-fade-enter");
          lyricTitle.classList.add("slide-fade-enter-active");

          showingTitle = true;

          // After 3 seconds, show the first verse
          setTimeout(() => {
            lyricTitle.classList.remove("slide-fade-enter-active");
            lyricTitle.classList.add("slide-fade-exit-active");

            setTimeout(() => {
              lyricTitle.classList.add("hidden");
              
              // Now show the first verse
              if (verses.length > 0) {
                currentSlide = 0;
                const currentVerse = verses[0];
                const textToDisplay =
                  typeof currentVerse === "string"
                    ? currentVerse
                    : currentVerse.text;
                
                lyricText.textContent = textToDisplay;
                lyricText.classList.remove("slide-fade-exit-active");
                lyricText.classList.add("slide-fade-enter");

                void lyricText.offsetWidth;

                lyricText.classList.remove("slide-fade-enter");
                lyricText.classList.add("slide-fade-enter-active");
                
                adjustFontSize();
                showingTitle = false;
              }
            }, 300);
          }, 3000); // Show title for 3 seconds
        }, 300);
      }

      function updateDisplay(newText) {
        if (!lyricText) return;

        // Animate out
        lyricText.classList.remove("slide-fade-enter-active");
        lyricText.classList.add("slide-fade-exit-active");

        setTimeout(() => {
          lyricText.textContent = newText;

          // Reset classes for animate in
          lyricText.classList.remove("slide-fade-exit-active");
          lyricText.classList.add("slide-fade-enter");

          // Trigger reflow
          void lyricText.offsetWidth;

          // Animate in
          lyricText.classList.remove("slide-fade-enter");
          lyricText.classList.add("slide-fade-enter-active");

          // Adjust font size after rendering
          adjustFontSize();
        }, 300); // Matches the exit transition duration
      }

      function adjustFontSize() {
        if (!lyricText || !document.getElementById("lyric-container")) return;

        const container = document.getElementById("lyric-container");
        // Reset to max size first
        lyricText.style.fontSize = "80px";

        // Check if text overflows
        while (
          lyricText.scrollHeight > container.clientHeight ||
          lyricText.scrollWidth > container.clientWidth
        ) {
          const currentSize = parseFloat(
            window.getComputedStyle(lyricText).fontSize
          );
          if (currentSize <= 16) break; // Minimum size
          lyricText.style.fontSize = currentSize - 2 + "px";
        }
      }

      // Allow controlling from the projector window itself as a fallback
      window.addEventListener("keydown", (e) => {
        if (verses.length === 0 || showingTitle) return;

        if (e.key === "ArrowRight" || e.key === "ArrowDown") {
          if (currentSlide < verses.length - 1) {
            currentSlide++;
            const currentVerse = verses[currentSlide];
            updateDisplay(
              typeof currentVerse === "string"
                ? currentVerse
                : currentVerse.text
            );
            // Sync back to main window just in case
            channel.postMessage({
              type: "SYNC_STATE",
              slideIndex: currentSlide,
            });
          }
        } else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
          if (currentSlide > 0) {
            currentSlide--;
            const currentVerse = verses[currentSlide];
            updateDisplay(
              typeof currentVerse === "string"
                ? currentVerse
                : currentVerse.text
            );
            channel.postMessage({
              type: "SYNC_STATE",
              slideIndex: currentSlide,
            });
          }
        }
      });

      // Adjust font size on window resize
      window.addEventListener("resize", adjustFontSize);
    </script>
  </body>
</html>
